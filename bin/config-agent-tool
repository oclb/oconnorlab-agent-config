#!/usr/bin/env python3
"""Manage the lab agent configuration checkout for Claude Code or Codex."""

from __future__ import annotations

import argparse
import os
import shutil
import subprocess
import sys
import tempfile
from dataclasses import dataclass
from pathlib import Path


GENERATED_MARKER = "Generated by lab-agent-config/bin/config-agent-tool"
OLD_CODEX_MARKER = "Generated by codex-config/bin/config-agent-tool"
OLD_CODEX_MARKER_2 = "Generated by codex-config/scripts/render-agents-override.sh"
AGENTS = {"claude", "codex"}


@dataclass(frozen=True)
class AgentConfig:
    name: str
    root: Path

    @property
    def global_prompt(self) -> Path:
        if self.name == "claude":
            return self.root / "global" / "CLAUDE.md"
        return self.root / "global" / "AGENTS.md"

    @property
    def skills_root(self) -> Path:
        return self.root / "skills"


@dataclass(frozen=True)
class Skill:
    name: str
    path: Path
    recommended_scope: str
    description: str


def repo_dir() -> Path:
    return Path(__file__).resolve().parents[1]


def agent_config(name: str) -> AgentConfig:
    if name not in AGENTS:
        raise SystemExit(f"Unknown agent: {name}")
    return AgentConfig(name=name, root=repo_dir() / name)


def codex_dir() -> Path:
    return Path(os.environ.get("CODEX_HOME", "~/.codex")).expanduser()


def claude_dir() -> Path:
    return Path(os.environ.get("CLAUDE_HOME", "~/.claude")).expanduser()


def project_dir() -> Path:
    try:
        result = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            check=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
        )
        return Path(result.stdout.strip()).resolve()
    except (subprocess.CalledProcessError, FileNotFoundError):
        return Path.cwd().resolve()


def parse_frontmatter(path: Path) -> dict[str, str]:
    lines = path.read_text(encoding="utf-8").splitlines()
    if not lines or lines[0].strip() != "---":
        return {}

    data: dict[str, str] = {}
    for line in lines[1:]:
        if line.strip() == "---":
            break
        if ":" not in line:
            continue
        key, value = line.split(":", 1)
        data[key.strip()] = value.strip().strip("\"'")
    return data


def skills(config: AgentConfig) -> list[Skill]:
    found: list[Skill] = []
    for skill_md in sorted(config.skills_root.glob("*/SKILL.md")):
        frontmatter = parse_frontmatter(skill_md)
        name = frontmatter.get("name") or skill_md.parent.name
        scope = frontmatter.get("recommended_scope", "none")
        if scope not in {"global", "project", "none"}:
            raise SystemExit(f"Invalid recommended_scope for {skill_md}: {scope}")
        found.append(
            Skill(
                name=name,
                path=skill_md.parent,
                recommended_scope=scope,
                description=frontmatter.get("description", ""),
            )
        )
    return found


def skill_map(config: AgentConfig) -> dict[str, Skill]:
    return {skill.name: skill for skill in skills(config)}


def target_skills_dir(config: AgentConfig, global_scope: bool) -> Path:
    if config.name == "claude":
        return claude_dir() / "skills" if global_scope else project_dir() / ".claude" / "skills"
    return codex_dir() / "skills" if global_scope else project_dir() / ".agents" / "skills"


def symlink_target(path: Path) -> Path | None:
    if not path.is_symlink():
        return None
    target = Path(os.readlink(path))
    if not target.is_absolute():
        target = path.parent / target
    return target.resolve(strict=False)


def is_managed_skill_link(path: Path, config: AgentConfig) -> bool:
    target = symlink_target(path)
    if target is None:
        return False
    try:
        target.relative_to(config.skills_root.resolve(strict=False))
        return True
    except ValueError:
        return False


def ensure_symlink(target: Path, link: Path, label: str) -> None:
    if not target.exists():
        raise SystemExit(f"Missing target for {label}: {target}")
    link.parent.mkdir(parents=True, exist_ok=True)
    if link.is_symlink():
        if link.resolve(strict=False) == target.resolve(strict=False):
            print(f"Already linked: {label}")
            return
        print(f"Replacing symlink: {label}")
        link.unlink()
    elif link.exists():
        backup = link.with_name(f"{link.name}.backup")
        suffix = 1
        while backup.exists():
            backup = link.with_name(f"{link.name}.backup.{suffix}")
            suffix += 1
        print(f"Backing up existing {label} to: {backup}")
        shutil.move(str(link), str(backup))
    print(f"Creating symlink: {link} -> {target}")
    link.symlink_to(target)


def remove_managed_link(link: Path, config: AgentConfig, label: str) -> bool:
    if is_managed_skill_link(link, config):
        print(f"Removing symlink: {label}")
        link.unlink()
        return True
    if link.exists() or link.is_symlink():
        print(f"Leaving unmanaged path in place: {link}")
    return False


def installed_names(config: AgentConfig, target_dir: Path) -> set[str]:
    if not target_dir.exists():
        return set()
    return {path.name for path in target_dir.iterdir() if is_managed_skill_link(path, config)}


def validate_skill_names(config: AgentConfig, names: list[str]) -> None:
    known = skill_map(config)
    unknown = [name for name in names if name not in known]
    if unknown:
        raise SystemExit(f"Unknown skill(s) for {config.name}: {', '.join(unknown)}")


def validate_remove_names(config: AgentConfig, names: list[str], target_dir: Path) -> None:
    known = skill_map(config)
    unknown = [
        name
        for name in names
        if name not in known and not is_managed_skill_link(target_dir / name, config)
    ]
    if unknown:
        raise SystemExit(f"Unknown skill(s) for {config.name}: {', '.join(unknown)}")


def refresh_links(config: AgentConfig, target_dir: Path) -> int:
    known = skill_map(config)
    refreshed = 0
    if not target_dir.exists():
        return refreshed
    for link in sorted(target_dir.iterdir()):
        if not is_managed_skill_link(link, config):
            continue
        if link.name not in known:
            print(f"Removing stale managed skill link: {link}")
            link.unlink()
            refreshed += 1
            continue
        ensure_symlink(known[link.name].path, link, f"{config.name} skill '{link.name}'")
        refreshed += 1
    return refreshed


def format_table(rows: list[list[str]]) -> str:
    widths = [max(len(row[idx]) for row in rows) for idx in range(len(rows[0]))]
    lines = []
    for row_idx, row in enumerate(rows):
        lines.append("  ".join(cell.ljust(widths[idx]) for idx, cell in enumerate(row)))
        if row_idx == 0:
            lines.append("  ".join("-" * width for width in widths))
    return "\n".join(lines)


def command_list_skills(args: argparse.Namespace) -> int:
    config = agent_config(args.agent)
    all_skills = skills(config)
    global_installed = installed_names(config, target_skills_dir(config, True))
    target_installed = installed_names(config, target_skills_dir(config, args.global_scope))
    visible_skills = all_skills
    if not args.global_scope:
        visible_skills = [skill for skill in visible_skills if skill.name not in global_installed]
    rows = [["skill", "recommended", "installed", "description"]]
    for skill in visible_skills:
        rows.append([
            skill.name,
            skill.recommended_scope,
            "yes" if skill.name in target_installed else "no",
            skill.description,
        ])
    print(f"Agent: {config.name}")
    print(f"Target: {target_skills_dir(config, args.global_scope)}")
    print(format_table(rows))
    return 0


def command_link_skills(args: argparse.Namespace) -> int:
    config = agent_config(args.agent)
    if args.add_all and args.add:
        raise SystemExit("--add-all cannot be combined with --add")
    if args.remove_all and args.remove:
        raise SystemExit("--remove-all cannot be combined with --remove")
    if (args.add_all or args.add) and (args.remove_all or args.remove):
        raise SystemExit("Add and remove operations cannot be combined")
    add = args.add or []
    remove = args.remove or []
    target_dir = target_skills_dir(config, args.global_scope)
    known = skill_map(config)
    if args.add_all:
        add = list(known)
    if args.remove_all:
        remove = sorted(installed_names(config, target_dir))
    validate_skill_names(config, add)
    validate_remove_names(config, remove, target_dir)
    if args.remove_all and not remove:
        print(f"Removed 0 managed {config.name} skill link(s) in {target_dir}.")
        return 0
    if not add and not remove:
        count = refresh_links(config, target_dir)
        print(f"Refreshed {count} managed {config.name} skill link(s) in {target_dir}.")
        return 0
    for name in remove:
        remove_managed_link(target_dir / name, config, f"{config.name} skill '{name}'")
    for name in add:
        ensure_symlink(known[name].path, target_dir / name, f"{config.name} skill '{name}'")
    return 0


def write_starter_codex_user_agents() -> None:
    user_agents = codex_dir() / "user" / "AGENTS.md"
    if user_agents.exists():
        print(f"User AGENTS source exists: {user_agents}")
        return
    print(f"Creating starter user AGENTS source: {user_agents}")
    user_agents.parent.mkdir(parents=True, exist_ok=True)
    user_agents.write_text(
        "Add personal Codex preferences here. This file is preserved by setup.\n",
        encoding="utf-8",
    )


def command_render_override(args: argparse.Namespace) -> int:
    if args.agent != "codex":
        raise SystemExit("render-override is only used for --agent codex")
    code_dir = codex_dir()
    user_agents = code_dir / "user" / "AGENTS.md"
    content_agents = agent_config("codex").global_prompt
    output = code_dir / "AGENTS.override.md"
    if not user_agents.exists():
        raise SystemExit(f"Missing user AGENTS source: {user_agents}")
    if not content_agents.exists():
        raise SystemExit(f"Missing content AGENTS source: {content_agents}")
    output.parent.mkdir(parents=True, exist_ok=True)
    if args.first_run and output.exists():
        current = output.read_text(encoding="utf-8", errors="replace")
        if (
            GENERATED_MARKER not in current
            and OLD_CODEX_MARKER not in current
            and OLD_CODEX_MARKER_2 not in current
        ):
            raise SystemExit(
                "Refusing to overwrite existing unmanaged AGENTS.override.md during first-run setup:\n"
                f"{output}"
            )
    rendered = (
        "<!--\n"
        f"{GENERATED_MARKER}. Do not edit directly.\n\n"
        "Sources:\n"
        f"- {user_agents}\n"
        f"- {content_agents}\n\n"
        "Regenerate after editing either source by running:\n"
        f"{code_dir / 'bin' / 'config-agent-tool'} render-override --agent codex\n"
        "-->\n\n"
        "# User Global Instructions\n\n"
        f"{user_agents.read_text(encoding='utf-8')}\n"
        "# Shared Codex Instructions\n\n"
        f"{content_agents.read_text(encoding='utf-8')}"
    )
    with tempfile.NamedTemporaryFile(
        "w",
        encoding="utf-8",
        dir=output.parent,
        delete=False,
        prefix=f"{output.name}.",
        suffix=".tmp",
    ) as tmp:
        tmp.write(rendered)
        tmp_path = Path(tmp.name)
    tmp_path.replace(output)
    print(f"Rendered {output}")
    return 0


def ensure_claude_import() -> None:
    cdir = claude_dir()
    cdir.mkdir(parents=True, exist_ok=True)
    claude_md = cdir / "CLAUDE.md"
    import_line = f"@{agent_config('claude').global_prompt}"
    stale_import_lines = {f"@{repo_dir() / 'global' / 'CLAUDE.md'}"}
    if claude_md.is_symlink():
        print(f"Backing up symlinked CLAUDE.md to {claude_md}.backup")
        backup = claude_md.with_name("CLAUDE.md.backup")
        suffix = 1
        while backup.exists():
            backup = claude_md.with_name(f"CLAUDE.md.backup.{suffix}")
            suffix += 1
        claude_md.rename(backup)
    if claude_md.exists():
        text = claude_md.read_text(encoding="utf-8", errors="replace")
        lines = text.splitlines()
        repaired_lines = []
        changed = False
        import_seen = False
        stale_replaced = False
        for line in lines:
            stripped = line.strip()
            if stripped in stale_import_lines:
                changed = True
                if not import_seen:
                    repaired_lines.append(import_line)
                    import_seen = True
                    stale_replaced = True
                continue
            if stripped == import_line:
                if import_seen:
                    changed = True
                    continue
                repaired_lines.append(import_line)
                import_seen = True
                changed = changed or line != import_line
                continue
            repaired_lines.append(line)
        if import_seen:
            if changed:
                claude_md.write_text("\n".join(repaired_lines) + "\n", encoding="utf-8")
                if stale_replaced:
                    print(f"Repaired stale Claude import in {claude_md}")
                else:
                    print(f"Normalized Claude import in {claude_md}")
                return
            print("Claude import already present.")
            return
        with claude_md.open("a", encoding="utf-8") as handle:
            handle.write("\n# Import shared lab agent configuration\n")
            handle.write(import_line + "\n")
        print(f"Added Claude import to {claude_md}")
    else:
        claude_md.write_text(
            "# User Claude Configuration\n\n"
            "# Import shared lab agent configuration\n"
            f"{import_line}\n",
            encoding="utf-8",
        )
        print(f"Created {claude_md}")


def repair_claude_managed_surface() -> None:
    cdir = claude_dir()
    for path in [cdir, cdir / "skills"]:
        path.mkdir(parents=True, exist_ok=True)
    ensure_claude_import()
    ensure_symlink(
        agent_config("claude").root / "global" / "settings.json",
        cdir / "settings.json",
        "Claude settings",
    )
    ensure_symlink(agent_config("claude").root / "hooks", cdir / "hooks", "Claude hooks")
    ensure_symlink(
        repo_dir() / "bin" / "config-agent-tool",
        cdir / "bin" / "config-agent-tool",
        "config-agent-tool",
    )


def install_claude() -> int:
    repair_claude_managed_surface()
    print("Install complete. No skills were installed automatically.")
    return 0


def install_codex() -> int:
    code_dir = codex_dir()
    for path in [code_dir, code_dir / "user", code_dir / "skills", code_dir / "bin"]:
        path.mkdir(parents=True, exist_ok=True)
    write_starter_codex_user_agents()
    ensure_symlink(repo_dir() / "bin" / "config-agent-tool", code_dir / "bin" / "config-agent-tool", "config-agent-tool")
    command_render_override(argparse.Namespace(agent="codex", first_run=True))
    print("Install complete. No skills were installed automatically.")
    return 0


def command_install(args: argparse.Namespace) -> int:
    if args.agent == "claude":
        return install_claude()
    if args.agent == "codex":
        return install_codex()
    raise SystemExit(f"Unknown agent: {args.agent}")


def command_update(args: argparse.Namespace) -> int:
    config = agent_config(args.agent)
    subprocess.run(["git", "-C", str(repo_dir()), "pull", "--ff-only"], check=True)
    if config.name == "codex":
        command_render_override(argparse.Namespace(agent="codex", first_run=False))
    if config.name == "claude":
        repair_claude_managed_surface()
    global_count = refresh_links(config, target_skills_dir(config, True))
    print(f"Refreshed {global_count} global {config.name} skill link(s).")
    project_target = target_skills_dir(config, False)
    if project_target.exists():
        project_count = refresh_links(config, project_target)
        print(f"Refreshed {project_count} project {config.name} skill link(s).")
    return 0


def command_repo_dir(args: argparse.Namespace) -> int:
    print(repo_dir())
    return 0


def add_agent_arg(parser: argparse.ArgumentParser) -> None:
    parser.add_argument("--agent", required=True, choices=sorted(AGENTS))


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="config-agent-tool")
    subcommands = parser.add_subparsers(dest="command", required=True)

    install = subcommands.add_parser("install")
    add_agent_arg(install)
    install.set_defaults(func=command_install)

    list_skills = subcommands.add_parser("list-skills")
    add_agent_arg(list_skills)
    list_skills.add_argument("--global", dest="global_scope", action="store_true")
    list_skills.set_defaults(func=command_list_skills)

    link_skills = subcommands.add_parser("link-skills")
    add_agent_arg(link_skills)
    link_skills.add_argument("--global", dest="global_scope", action="store_true")
    link_skills.add_argument("--add", nargs="+")
    link_skills.add_argument("--add-all", action="store_true")
    link_skills.add_argument("--remove", nargs="+")
    link_skills.add_argument("--remove-all", action="store_true")
    link_skills.set_defaults(func=command_link_skills)

    render = subcommands.add_parser("render-override")
    add_agent_arg(render)
    render.add_argument("--first-run", action="store_true")
    render.set_defaults(func=command_render_override)

    update = subcommands.add_parser("update")
    add_agent_arg(update)
    update.set_defaults(func=command_update)

    repo = subcommands.add_parser("repo-dir")
    repo.set_defaults(func=command_repo_dir)
    return parser


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
