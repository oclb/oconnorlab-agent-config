{
  "model": "opus",
  "hooks": {
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/Dropbox/GitHub/claude-config/claude-notify-hook.sh 'Claude Code' 'Awaiting your input'",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/Dropbox/GitHub/claude-config/claude-notify-hook.sh 'Claude Code' 'Task completed'",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "pluginDirs": [
    "~/Dropbox/GitHub/claude-config/skills",
    "/n/data1/hms/dbmi/oconnor/lab/luke/claude/skills"
  ],
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true
  },
  "permissions": {
    "allowWithinAllow": {
      "WebFetch": [
        "github.com/oclb",
        "github.com/ericbuess/claude-code-docs",
        "harvardmed.atlassian.net",
        "docs.astral.sh",
        "ntfy.sh",
        "docs.anthropic.com"
      ]
    }
  }
}
