{
  "// NOTE": "This is an example user-specific settings file",
  "// SETUP": "Copy to settings.user.json (which is gitignored)",
  "// USAGE": "Add your personal overrides here - they won't be committed",

  "// Example overrides": {
    "model": "opus",
    "maxTokens": 8096,

    "hooks": {
      "// Your custom hooks": "Add additional hooks here"
    },

    "permissions": {
      "allowWithinAllow": {
        "WebFetch": [
          "example.com",
          "your-private-domain.com"
        ]
      }
    },

    "// Custom settings": {
      "preferredEditor": "vim",
      "autoCommit": false
    }
  },

  "// NOTE 2": "Remove the comment keys (// ...) when creating your actual settings.user.json"
}
