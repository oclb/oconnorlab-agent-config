{
  "permissions": {
    "allow": [
      "Read(~/.claude/behavior.conf)",
      "Edit(~/.claude/behavior.conf)",
      "Bash(remote-bridge *)",
      "Bash(*remote-bridge/target/release/remote-bridge *)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:harvardmed.atlassian.net)",
      "WebFetch(domain:docs.astral.sh)",
      "WebFetch(domain:ntfy.sh)",
      "WebFetch(domain:docs.ntfy.sh)",
      "WebFetch(domain:docs.rc.fas.harvard.edu)",
      "Bash(git diff *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git stash *)",
      "Bash(git show *)",
      "Bash(git rev-parse *)",
      "Bash(source *)",
      "Bash(echo *)",
      "Read(//Users/loconnor/Documents/claude/feedback/**)",
      "Write(//Users/loconnor/Documents/claude/feedback/**)",
      "Edit(//Users/loconnor/Documents/claude/feedback/**)",
      "Bash(git -C /Users/loconnor/Documents/claude add feedback/*)",
      "Bash(git -C /Users/loconnor/Documents/claude commit *)"
    ]
  },
  "model": "opus",
  "hooks": {
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify.sh 'Claude Code' 'Awaiting your input'",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify.sh 'Claude Code' 'Task completed'",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true
  }
}
